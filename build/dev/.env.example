# =============================================================================
# Velpos — Dev Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# Dev mode: only MySQL runs in Docker.
# Backend and frontend run on the host machine.
# =============================================================================

# --- MySQL (Docker) ---
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=velpos
MYSQL_HOST_PORT=3307

# --- Database (backend reads this via environment) ---
DATABASE_URL=mysql+aiomysql://root:root123456@localhost:3307/velpos

# --- Backend ---
BACKEND_PORT=8083
SERVER_HOST=0.0.0.0

# --- Frontend ---
FRONTEND_PORT=8911

# --- Claude Code ---
# CLAUDE_CLI_PATH is auto-detected via `which claude` at startup.
# Only set this if claude is not in your PATH:
# CLAUDE_CLI_PATH=/path/to/claude
CLAUDE_PERMISSION_MODE=acceptEdits
DEFAULT_MODEL=claude-opus-4-6

# --- Projects ---
PROJECTS_ROOT_DIR=~/claude-projects

# --- CORS ---
CORS_ALLOW_ORIGINS=*
