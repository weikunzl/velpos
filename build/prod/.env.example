# =============================================================================
# Velpos — Production Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# Prod mode: everything runs in Docker (MySQL + backend + frontend/nginx).
# The following are auto-configured by docker-compose and should NOT be set:
#   DATABASE_URL, CLAUDE_CLI_PATH, PROJECTS_ROOT_DIR
# =============================================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=velpos

# --- Ports ---
APP_PORT=80

# --- Host directory mounted into container as /data/projects ---
# IMPORTANT: Use absolute path. Tilde (~) is NOT expanded in Docker .env files.
# Example: /home/youruser/.agent_projects
PROJECTS_HOST_DIR=/tmp/agent_projects

# --- Claude Code ---
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_PERMISSION_MODE=acceptEdits
DEFAULT_MODEL=claude-opus-4-6

# --- CORS (optional, default allows all) ---
CORS_ALLOW_ORIGINS=*
