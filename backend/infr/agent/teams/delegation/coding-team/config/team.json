{
  "id": "coding-team",
  "name_en": "Coding Team",
  "name_zh": "编码团队",
  "description_en": "Architect designs, coder implements, tester validates.",
  "description_zh": "架构师设计，开发者实现，测试者验证。",
  "mode": "delegation",
  "pipeline": [
    {
      "role": "architect",
      "role_label": "Architect",
      "handoff_input": "User requirements",
      "handoff_output": "Technical design document"
    },
    {
      "role": "coder",
      "role_label": "Coder",
      "handoff_input": "Technical design",
      "handoff_output": "Implemented code"
    },
    {
      "role": "tester",
      "role_label": "Tester",
      "handoff_input": "Code changes",
      "handoff_output": "Test results and feedback"
    }
  ],
  "default_config": {
    "max_concurrent": 2,
    "worker_max_turns": 50,
    "worker_max_budget_usd": 1.0,
    "file_checkpointing": true
  }
}
