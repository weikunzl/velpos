{
  "id": "code-review-team",
  "name_en": "Code Review Team",
  "name_zh": "代码审查团队",
  "description_en": "Author writes code, reviewer provides feedback. Members can ask each other for help.",
  "description_zh": "开发者编写代码，审查者提供反馈。成员之间可以互相请求协助。",
  "mode": "collaboration",
  "members": [
    {
      "role": "author",
      "role_label": "Author"
    },
    {
      "role": "reviewer",
      "role_label": "Reviewer"
    }
  ],
  "default_workflow": ["author", "reviewer"],
  "default_config": {
    "max_concurrent": 2,
    "worker_max_turns": 30,
    "worker_max_budget_usd": 1.0,
    "max_depth": 2,
    "file_checkpointing": true
  }
}
